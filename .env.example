# AI Log Analyzer — environment variables
# Copy to .env and edit. Nothing here is required: the tool runs against the
# FRR docker logs out of the box.

# ── Server ────────────────────────────────────────────────────────────────────
ANALYZER_PORT=6060

# ── LLM provider ──────────────────────────────────────────────────────────────
# local       : Docker Model Runner (TCP 12434 or auto-detected Unix socket)
# claude      : Anthropic Claude first, fall back to local if Claude is unreachable
# claude-only : Anthropic Claude only — never call local
LLM_PROVIDER=local
LLM_ENABLED=true
LLM_TIMEOUT=60

# ── Local LLM (Docker Model Runner) ───────────────────────────────────────────
MODEL_RUNNER_URL=http://localhost:12434
LLM_MODEL=ai/qwen3:latest

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
